# Docker-based Sandbox Configuration Template
# Copy this file to .env.docker and modify as needed

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Enable CORS for development (set to false for production)
MCP_ENABLE_CORS=true

# Server port (default: 8775)
MCP_SERVER_PORT=8775

# Server host (default: localhost, use 0.0.0.0 to bind to all interfaces)
MCP_SERVER_HOST=localhost

# =============================================================================
# Docker-based Sandbox Configuration
# =============================================================================

# Container runtime (docker or podman)
CONTAINER_RUNTIME=docker

# Default Docker images
#LOCALSANDBOX_PYTHON_IMAGE=docker.io/library/python:3.11-slim
LOCALSANDBOX_PYTHON_IMAGE=python:3.11-slim
LOCALSANDBOX_NODE_IMAGE=node:18-slim

# Default execution timeout (30 minutes)
LOCALSANDBOX_DEFAULT_TIMEOUT=1800

# =============================================================================
# Session Management
# =============================================================================

# Maximum number of concurrent sessions
MSB_MAX_SESSIONS=5

# Session timeout in seconds (1 hour)
MSB_SESSION_TIMEOUT=3600

# Default flavor (small, medium, large)
MSB_DEFAULT_FLAVOR=small

# Session cleanup interval in seconds
MSB_SESSION_CLEANUP_INTERVAL=60

# =============================================================================
# Flavor Configuration (Optional)
# =============================================================================

# Custom flavor configurations in JSON format
# Overrides the default flavor settings:
# - small: 1GB RAM, 1 CPU
# - medium: 2GB RAM, 2 CPU  
# - large: 4GB RAM, 4 CPU
# MSB_FLAVOR_CONFIGS={"small": {"memory_mb": 1024, "cpu_limit": 1.0}, "medium": {"memory_mb": 2048, "cpu_limit": 2.0}, "large": {"memory_mb": 4096, "cpu_limit": 4.0}}

# =============================================================================
# Resource Limits
# =============================================================================

# Maximum total memory across all sessions (4GB)
MSB_MAX_TOTAL_MEMORY_MB=2048

# Maximum execution time per request (30 minutes)
MSB_MAX_EXECUTION_TIME=1800

# Execution timeout (30 minutes)
MSB_EXECUTION_TIMEOUT=1800

# =============================================================================
# Volume Mapping - Development Directories
# =============================================================================

# Enable volume mapping between host and containers
MSB_ENABLE_VOLUME_MAPPING=true

# Shared volume paths in JSON array format
# Format: ["host_path:container_path", "host_path2:container_path2"]
# Example: ["/Users/username/projects:/workspace", "/tmp/shared:/tmp/shared"]
MSB_SHARED_VOLUME_PATH='["./data:/shared"]'

# =============================================================================
# Logging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
MSB_LOG_LEVEL=INFO

# Log format (text or json)
MSB_LOG_FORMAT=text

# =============================================================================
# Security Settings (Optional)
# =============================================================================

# Network mode for containers (none, bridge, host)
# MSB_NETWORK_MODE=none

# Disable network access in containers (true/false)
# MSB_DISABLE_NETWORK=false

# Read-only root filesystem (true/false)
# MSB_READ_ONLY_ROOT=false