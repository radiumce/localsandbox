# LocalSandbox Configuration Example
# Copy this file to .env and modify as needed

# Container Runtime Configuration
# Supported values: docker, podman
CONTAINER_RUNTIME=docker

# Default Container Images
# Python sandbox image
LOCALSANDBOX_PYTHON_IMAGE=python:3.11-slim
# Node.js sandbox image
LOCALSANDBOX_NODE_IMAGE=node:18-slim

# Default Resource Limits
# Default memory limit in MB
LOCALSANDBOX_DEFAULT_MEMORY=512
# Default CPU limit (number of CPUs)
LOCALSANDBOX_DEFAULT_CPU=1.0
# Default command execution timeout in seconds
LOCALSANDBOX_DEFAULT_TIMEOUT=30

# Container Configuration
# Default working directory inside containers
LOCALSANDBOX_WORKING_DIR=/workspace